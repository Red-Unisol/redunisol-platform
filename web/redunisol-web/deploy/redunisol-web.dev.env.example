TARGET_DIR=/opt/redunisol-web-dev
WEB_BIND=127.0.0.1:3020:80

APP_NAME="Red Unisol"
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://dev.redunisol.com.ar

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_DATABASE=redunisol_web_dev
DB_USERNAME=redunisol_web_dev
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=dev.redunisol.com.ar

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=predis
REDIS_PASSWORD=null

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@redunisol.com.ar
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

KESTRA_FORM_WEBHOOK_URL=
KESTRA_FORM_WEBHOOK_TIMEOUT_SECONDS=15
KESTRA_FORM_DEFAULT_LEAD_SOURCE=Google