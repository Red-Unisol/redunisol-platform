{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Runtime Env: Generate Shared Key",
      "type": "shell",
      "command": "python",
      "args": [
        "kestra/tools/manage_encrypted_env.py",
        "generate-key",
        "--output",
        "kestra/platform/infra/kestra-runtime.local.key"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Runtime Env: Decrypt All",
      "type": "shell",
      "command": "python",
      "args": [
        "kestra/tools/manage_encrypted_env.py",
        "decrypt-many",
        "--key-file",
        "kestra/platform/infra/kestra-runtime.local.key",
        "--pair",
        "kestra/platform/infra/kestra-runtime.env.enc=kestra/platform/infra/kestra-runtime.env",
        "--pair",
        "web/herramientas/deploy/herramientas.dev.env.enc=web/herramientas/deploy/herramientas.dev.env",
        "--pair",
        "web/herramientas/deploy/herramientas.prod.env.enc=web/herramientas/deploy/herramientas.prod.env",
        "--force"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Runtime Env: Encrypt All",
      "type": "shell",
      "command": "python",
      "args": [
        "kestra/tools/manage_encrypted_env.py",
        "encrypt-many",
        "--key-file",
        "kestra/platform/infra/kestra-runtime.local.key",
        "--pair",
        "kestra/platform/infra/kestra-runtime.env=kestra/platform/infra/kestra-runtime.env.enc",
        "--pair",
        "web/herramientas/deploy/herramientas.dev.env=web/herramientas/deploy/herramientas.dev.env.enc",
        "--pair",
        "web/herramientas/deploy/herramientas.prod.env=web/herramientas/deploy/herramientas.prod.env.enc",
        "--force"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Herramientas: Laravel Serve",
      "type": "shell",
      "command": "php",
      "args": [
        "artisan",
        "serve",
        "--host=127.0.0.1",
        "--port=3010"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web/herramientas"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting Laravel development server.*",
          "endsPattern": ".*http://127\\.0\\.0\\.1:3010.*"
        }
      }
    },
    {
      "label": "Herramientas: Vite Dev",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "5173"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web/herramientas"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*(Local|local):.*127\\.0\\.0\\.1:5173.*"
        }
      }
    },
    {
      "label": "Herramientas: Start Local Dev",
      "dependsOn": [
        "Herramientas: Laravel Serve",
        "Herramientas: Vite Dev"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Herramientas: Build Frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web/herramientas"
      },
      "problemMatcher": []
    },
    {
      "label": "Herramientas: Docker Up",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "--build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/web/herramientas"
      },
      "problemMatcher": []
    }
  ]
}