# Configuracion principal
TRANSFERENCIAS_SERVER_BASE_URL=https://tu-server
TRANSFERENCIAS_SERVER_CLIENT_ID=tu-client-id
TRANSFERENCIAS_SERVER_CLIENT_SECRET=tu-client-secret

# Opcionales frecuentes
TRANSFERENCIAS_CORE_BASE_URL=https://celesol.dyndns.org:5050
TRANSFERENCIAS_OPERATOR_NAME=Santiago
TRANSFERENCIAS_POLL_INTERVAL_SECONDS=20
TRANSFERENCIAS_REQUEST_TIMEOUT_SECONDS=15
TRANSFERENCIAS_RECEIPTS_DIR=receipts
TRANSFERENCIAS_COMPLETED_LOG_PATH=transferencias_realizadas.jsonl
TRANSFERENCIAS_SMOKE_TRANSFERS_DIR=smoke-transfers

# Certificados / auth opcional
TRANSFERENCIAS_SERVER_ALLOW_INVALID_CERTS=false
TRANSFERENCIAS_CORE_ALLOW_INVALID_CERTS=true

# Coinag para habilitar Transferir
TRANSFERENCIAS_COINAG_TRANSFER_API_BASE=https://tu-coinag-api-v2
TRANSFERENCIAS_COINAG_LOOKUP_API_BASE=https://tu-coinag-api-v1
TRANSFERENCIAS_COINAG_BALANCE_API_BASE=https://tu-coinag-cuentavista
TRANSFERENCIAS_COINAG_TOKEN_URL=https://tu-coinag-token
TRANSFERENCIAS_COINAG_USERNAME=tu-usuario
TRANSFERENCIAS_COINAG_PASSWORD=tu-password
TRANSFERENCIAS_COINAG_CUIT_DEBITO=20123456789
TRANSFERENCIAS_COINAG_CBU_DEBITO=2850590940090418135201
TRANSFERENCIAS_COINAG_TITULAR_DEBITO=REDUNISOL

# Compatibilidad legacy: si queres una sola base para lookup y transferencia,
# podes usar solo esta variable en lugar de las dos anteriores.
# TRANSFERENCIAS_COINAG_API_BASE=https://tu-coinag-api

# Opcionales de Coinag
TRANSFERENCIAS_COINAG_CLIENT_ID=
TRANSFERENCIAS_COINAG_CLIENT_SECRET=
TRANSFERENCIAS_COINAG_CONCEPTO=VAR
TRANSFERENCIAS_COINAG_DESCRIPCION=
TRANSFERENCIAS_COINAG_ENDPOINT=/Transferencia
TRANSFERENCIAS_COINAG_SCOPE=
TRANSFERENCIAS_COINAG_AUTH_SCHEME=Bearer
TRANSFERENCIAS_COINAG_ID_EMPRESA=
TRANSFERENCIAS_COINAG_ID_SEQ_PATH=transferencias_coinag_seq.txt
TRANSFERENCIAS_COINAG_ALLOW_INVALID_CERTS=false

# SSH opcional hacia Coinag
TRANSFERENCIAS_COINAG_SSH_ENABLED=false
TRANSFERENCIAS_COINAG_SSH_HOST=
TRANSFERENCIAS_COINAG_SSH_PORT=22
TRANSFERENCIAS_COINAG_SSH_USER=
TRANSFERENCIAS_COINAG_SSH_PRIVATE_KEY_PATH=
TRANSFERENCIAS_COINAG_SSH_HOST_PUBLIC_KEY_PATH=
TRANSFERENCIAS_COINAG_SSH_ORIGINATOR_ADDRESS=127.0.0.1

# Si queres forzar otra ubicacion del archivo de config en vez de usar
# transferencias.env al lado del .exe, podes definir esto en el entorno del sistema:
# TRANSFERENCIAS_CONFIG_PATH=C:\ruta\archivo\transferencias.env

# En debug builds, si queres forzar otra ruta para el log:
# TRANSFERENCIAS_DEBUG_LOG_PATH=C:\ruta\transferencias-debug.log
