COMPOSE_PROJECT_NAME=kestra
KESTRA_VERSION=latest
POSTGRES_VERSION=16
POSTGRES_DB=kestra
POSTGRES_USER=kestra
POSTGRES_PASSWORD=change-me-postgres
KESTRA_ADMIN_EMAIL=admin@example.com
KESTRA_ADMIN_PASSWORD=change-me-kestra
KESTRA_PUBLIC_URL=http://localhost:8080/
ENV_VIMARX_TIMEOUT_SECONDS=180
ENV_VIMARX_VERIFY_TLS=false
ENV_BITRIX24_BASE_URL=https://your-company.bitrix24.com/rest
ENV_BITRIX24_CONTACT_CUIL_FIELD=UF_CRM_CONTACT_CUIL
ENV_BITRIX24_LEAD_PROCESSING_POLICY_FIELD=UF_CRM_PROCESSING_POLICY
ENV_BITRIX24_LEAD_PROCESSING_POLICY_SKIP=No procesar
ENV_BITRIX24_LEAD_PROCESSING_POLICY_PROCESS=Procesar
ENV_BITRIX24_LEAD_CUIL_FIELD=UF_CRM_LEAD_CUIL
ENV_BITRIX24_LEAD_EMPLOYMENT_STATUS_FIELD=UF_CRM_LEAD_EMPLOYMENT_STATUS
ENV_BITRIX24_LEAD_PAYMENT_BANK_FIELD=UF_CRM_LEAD_PAYMENT_BANK
ENV_BITRIX24_LEAD_PROVINCE_FIELD=UF_CRM_LEAD_PROVINCE
ENV_BITRIX24_LEAD_SOURCE_FIELD=UF_CRM_LEAD_SOURCE
ENV_BITRIX24_LEAD_REJECTION_REASON_FIELD=UF_CRM_LEAD_REJECTION_REASON
ENV_BITRIX24_LEAD_STATUS_QUALIFIED=QUALIFIED
ENV_BITRIX24_LEAD_STATUS_REJECTED=UC_1P8I07
ENV_BITRIX24_TIMEOUT_SECONDS=30
ENV_CIDI_BASE_URL=https://url-de-cidi.ar
ENV_CIDI_CLIENT_ID=cliente-id-cidi
ENV_CAJA_BASE_URL=https://url-de-caja-jubilaciones.ar
ENV_CAJA_ID_TIPO_USUARIO=id-tipo-usuario
SECRET_BITRIX24_WEBHOOK_PATH=base64-encoded-webhook-path
SECRET_BITRIX24_FORM_WEBHOOK_KEY=base64-encoded-webhook-key
SECRET_ANALISIS_CREDITO_WEBHOOK_KEY=base64-encoded-webhook-key
SECRET_DEVEXPRESS_EVALUATE_API_BASE_URL=base64-encoded-base-url
SECRET_CIDI_USER=base64-encoded-user
SECRET_CIDI_PASS=base64-encoded-pass
SECRET_CIDI_CLIENT_SECRET=base64-encoded-client-secret
SECRET_CAJA_ENCRYPT_PASS=base64-encoded-encrypt-pass
SECRET_ANALISIS_CREDITO_CAJA_WEBHOOK_KEY=base64-encoded-webhook-key
